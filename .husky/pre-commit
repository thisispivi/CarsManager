#!/usr/bin/env sh

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"

cd "$REPO_ROOT/cars_manager" || {
  echo "cars_manager folder not found under repo root: $REPO_ROOT" >&2
  exit 1
}

LINT_STAGED="$REPO_ROOT/node_modules/.bin/lint-staged"

if [ -f "$LINT_STAGED" ]; then
  "$LINT_STAGED" --config "$REPO_ROOT/.lintstagedrc.js" || {
    echo "lint-staged failed, aborting commit." >&2
    exit 1
  }
else
  echo "⚠️  lint-staged not installed — run 'npm install' at repo root to enable pre-commit linting." >&2
  dart format --set-exit-if-changed lib/ || {
    echo "dart format found issues, aborting commit." >&2
    exit 1
  }
  dart analyze || {
    echo "dart analyze failed, aborting commit." >&2
    exit 1
  }
fi

flutter test || {
  echo "Tests failed, aborting commit." >&2
  exit 1
}
