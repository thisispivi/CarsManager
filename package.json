{
  "name": "carsmanager",
  "version": "1.0.0",
  "private": true,
  "description": "Root package for Cars Manager repository tooling (commit linting, pre-commit hooks).",
  "scripts": {
    "prepare": "husky",
    "format": "cd cars_manager && dart format .",
    "format:check": "cd cars_manager && dart format --set-exit-if-changed .",
    "analyze": "cd cars_manager && flutter analyze --fatal-infos",
    "generate": "cd cars_manager && dart run build_runner build --delete-conflicting-outputs",
    "test": "cd cars_manager && flutter test",
    "build:android": "cd cars_manager && flutter build apk --release --split-per-abi",
    "build:web": "cd cars_manager && flutter build web --release",
    "commitlint": "commitlint --edit",
    "lint-staged": "lint-staged --config .lintstagedrc.js",
    "verify": "npm run format:check && npm run analyze && npm test"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0"
  }
}
